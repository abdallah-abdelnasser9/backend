<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h4>Shopping Cart <span class="badge bg-primary"><%= cart.totalItems %> items</span></h4>
            </div>
            <div class="card-body">
                <% if (cart.items && cart.items.length > 0) { %>
                    <% cart.items.forEach((item, index) => { %>
                    <div class="cart-item row align-items-center mb-3 pb-3 border-bottom">
                        <div class="col-md-2">
                            <img src="<%= item.image || 'https://via.placeholder.com/100' %>" 
                                 class="img-fluid rounded" alt="<%= item.name %>" 
                                 style="width: 80px; height: 80px; object-fit: cover;">
                        </div>
                        <div class="col-md-4">
                            <h6 class="mb-1"><%= item.name %></h6>
                            <p class="text-muted mb-0 small">$<%= item.price %> each</p>
                        </div>
                        <div class="col-md-3">
                            <div class="input-group input-group-sm" style="width: 120px;">
                                <button class="btn btn-outline-secondary" 
                                        onclick="updateQuantity(<%= index %>, <%= item.quantity - 1 %>)">
                                    -
                                </button>
                                <input type="number" class="form-control text-center" 
                                       id="qty-<%= index %>" value="<%= item.quantity %>" min="1">
                                <button class="btn btn-outline-secondary" 
                                        onclick="updateQuantity(<%= index %>, <%= item.quantity + 1 %>)">
                                    +
                                </button>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <h6 class="mb-0">$<%= (item.price * item.quantity).toFixed(2) %></h6>
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-danger btn-sm" 
                                    onclick="removeItem(<%= index %>)">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    <% }) %>
                    
                    <div class="text-end mt-4">
                        <button class="btn btn-outline-danger" onclick="clearCart()">
                            <i class="fas fa-trash"></i> Clear Cart
                        </button>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <h5>Your cart is empty</h5>
                        <p class="text-muted">Add some products to get started!</p>
                        <a href="/products" class="btn btn-primary">
                            <i class="fas fa-shopping-bag"></i> Shop Now
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    
    <!-- Inside views/cart/index.ejs -->

<div class="col-md-4">
    <div class="card">
        <div class="card-header">
            <h4>Order Summary</h4>
        </div>
        <div class="card-body">
            <% if (cart.items && cart.items.length > 0) { %>
                <% cart.items.forEach(item => { %>
                <div class="d-flex justify-content-between mb-2">
                    <div>
                        <small><%= item.name %> x <%= item.quantity %></small>
                    </div>
                    <small>$<%= (item.price * item.quantity).toFixed(2) %></small>
                </div>
                <% }) %>
                
                <hr>
                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal</span>
                    <span>$<%= cart.totalPrice.toFixed(2) %></span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Shipping</span>
                    <span>$10.00</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Tax (5%)</span>
                    <span>$<%= (cart.totalPrice * 0.05).toFixed(2) %></span>
                </div>
                <hr>
                <div class="d-flex justify-content-between mb-3">
                    <strong>Total</strong>
                    <strong>$<%= (cart.totalPrice + 10 + cart.totalPrice * 0.05).toFixed(2) %></strong>
                </div>
                
                <!-- UPDATED CHECKOUT BUTTON SECTION -->
                <% if (isAuthenticated) { %>
                    <a href="/checkout" class="btn btn-primary w-100 mb-2">
                        <i class="fas fa-lock"></i> Proceed to Checkout
                    </a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-warning w-100 mb-2">
                        <i class="fas fa-sign-in-alt"></i> Login to Checkout
                    </a>
                <% } %>
                <!-- END OF UPDATED SECTION -->
                
                <a href="/products" class="btn btn-outline-primary w-100">
                    <i class="fas fa-shopping-bag"></i> Continue Shopping
                </a>
            <% } else { %>
                <div class="text-center">
                    <p class="text-muted">Cart is empty</p>
                    <a href="/products" class="btn btn-primary w-100">Start Shopping</a>
                </div>
            <% } %>
        </div>
    </div>
</div>
</div>

<script>
function updateQuantity(index, newQuantity) {
    if (newQuantity < 1) return;
    
    $.ajax({
        url: '/cart/update',
        method: 'POST',
        data: { 
            index: index,
            quantity: newQuantity
        },
        success: function(response) {
            if (response.success) {
                location.reload();
            }
        },
        error: function() {
            alert('Error updating quantity');
        }
    });
}

function removeItem(index) {
    if (confirm('Remove this item from cart?')) {
        $.ajax({
            url: '/cart/remove',
            method: 'POST',
            data: { index: index },
            success: function(response) {
                if (response.success) {
                    location.reload();
                }
            },
            error: function() {
                alert('Error removing item');
            }
        });
    }
}

function clearCart() {
    if (confirm('Clear all items from cart?')) {
        $.ajax({
            url: '/cart/clear',
            method: 'POST',
            success: function(response) {
                if (response.success) {
                    location.reload();
                }
            },
            error: function() {
                alert('Error clearing cart');
            }
        });
    }
}
</script>