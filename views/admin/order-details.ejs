<%- layout('layouts/admin-simple') -%>

<div class="container-fluid">
    <!-- Back Button -->
    <a href="/admin/orders" class="btn btn-outline-secondary mb-4">
        <i class="fas fa-arrow-left me-2"></i>Back to Orders
    </a>
    
    <!-- Order Header -->
    <div class="card border-primary mb-4">
        <div class="card-header bg-primary text-white">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h2 class="mb-0">
                        <i class="fas fa-shopping-bag me-2"></i>
                        Order #<%= order.orderId %>
                    </h2>
                </div>
                <div class="col-md-4 text-end">
                    <h3 class="mb-0">$<%= order.totalAmount.toFixed(2) %></h3>
                    <small>Placed on <%= new Date(order.createdAt).toLocaleString() %></small>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Flash Messages -->
    <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <div class="row">
        <!-- Left Column - Order Details -->
        <div class="col-lg-8">
            <!-- Order Items -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-boxes me-2"></i>Order Items</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Quantity</th>
                                    <th>Price</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% order.items.forEach(item => { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <% if (item.product && item.product.images && item.product.images[0]) { %>
                                            <img src="<%= item.product.images[0] %>" 
                                                 class="rounded me-3" 
                                                 style="width: 60px; height: 60px; object-fit: cover;">
                                            <% } %>
                                            <div>
                                                <h6 class="mb-0"><%= item.name || item.product?.name || 'Product' %></h6>
                                                <small class="text-muted">
                                                    Product ID: <%= item.product ? item.product._id : 'N/A' %>
                                                </small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><%= item.quantity %></td>
                                    <td>$<%= item.price.toFixed(2) %></td>
                                    <td><strong>$<%= (item.price * item.quantity).toFixed(2) %></strong></td>
                                </tr>
                                <% }) %>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Subtotal:</strong></td>
                                    <td>$<%= order.subtotal.toFixed(2) %></td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Shipping:</strong></td>
                                    <td>$<%= order.shippingFee.toFixed(2) %></td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Tax:</strong></td>
                                    <td>$<%= order.tax.toFixed(2) %></td>
                                </tr>
                                <tr class="table-active">
                                    <td colspan="3" class="text-end"><strong>Total Amount:</strong></td>
                                    <td><strong class="h5">$<%= order.totalAmount.toFixed(2) %></strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            
            <!-- Customer Information -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-user me-2"></i>Customer Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Name:</strong> <%= order.user?.name || 'N/A' %></p>
                            <p><strong>Email:</strong> <%= order.user?.email || 'N/A' %></p>
                            <p><strong>Phone:</strong> <%= order.user?.phone || 'N/A' %></p>
                            <p><strong>Customer ID:</strong> <%= order.user?._id || order.user %></p>
                        </div>
                        <div class="col-md-6">
                            <% if (order.deliveredAt) { %>
                            <p><strong>Delivered At:</strong> <%= new Date(order.deliveredAt).toLocaleString() %></p>
                            <% } %>
                            <% if (order.cancelledAt) { %>
                            <p><strong>Cancelled At:</strong> <%= new Date(order.cancelledAt).toLocaleString() %></p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Right Column - Order Management -->
        <div class="col-lg-4">
            <!-- Order Status Update -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-cog me-2"></i>Update Order</h5>
                </div>
                <div class="card-body">
                    <form action="/admin/orders/<%= order.orderId %>/status" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Order Status</label>
                            <select class="form-select" name="status" required>
                                <% statusOptions.forEach(status => { %>
                                <option value="<%= status %>" <%= order.status === status ? 'selected' : '' %>>
                                    <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                                </option>
                                <% }) %>
                            </select>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Payment Status</label>
                            <select class="form-select" name="paymentStatus" required>
                                <% paymentStatusOptions.forEach(status => { %>
                                <option value="<%= status %>" <%= order.paymentStatus === status ? 'selected' : '' %>>
                                    <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                                </option>
                                <% }) %>
                            </select>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-save me-2"></i>Update Order
                        </button>
                    </form>
                    
                    <hr class="my-3">
                    
                    <!-- Delete Order -->
                    <form action="/admin/orders/<%= order.orderId %>/delete" method="POST" 
                          onsubmit="return confirm('Are you sure you want to delete this order? This action cannot be undone.');">
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="fas fa-trash me-2"></i>Delete Order
                        </button>
                    </form>
                </div>
            </div>
            
            <!-- Payment Information -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-credit-card me-2"></i>Payment Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Method:</strong> 
                        <span class="text-capitalize"><%= order.paymentMethod %></span>
                    </p>
                    <p><strong>Payment ID:</strong> 
                        <code><%= order.paymentId || 'N/A' %></code>
                    </p>
                    <p><strong>Payment Status:</strong> 
                        <span class="badge <%= order.paymentStatus === 'completed' ? 'bg-success' : order.paymentStatus === 'failed' ? 'bg-danger' : 'bg-warning' %>">
                            <%= order.paymentStatus %>
                        </span>
                    </p>
                </div>
            </div>
            
            <!-- Shipping Address -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>Shipping Address</h5>
                </div>
                <div class="card-body">
                    <% if (order.shippingAddress) { %>
                    <p>
                        <strong><%= order.shippingAddress.street %></strong><br>
                        <%= order.shippingAddress.city %>, 
                        <%= order.shippingAddress.state %> 
                        <%= order.shippingAddress.zipCode %><br>
                        <%= order.shippingAddress.country %>
                    </p>
                    <% } else { %>
                    <p class="text-muted">No shipping address provided</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>