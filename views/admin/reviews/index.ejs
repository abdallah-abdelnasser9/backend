<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Customer Reviews</h1>
            <p class="mb-0">Manage product reviews and ratings</p>
        </div>
    </div>

    <!-- Flash Messages -->
    <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i><%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i><%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Reviews Table -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">All Reviews</h6>
        </div>
        <div class="card-body">
            <% if (reviews && reviews.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Product</th>
                                <th>Customer</th>
                                <th>Rating</th>
                                <th>Review</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reviews.forEach(review => { %>
                            <tr>
                                <td class="text-muted"><small><%= review._id.toString().substring(0, 8) %>...</small></td>
                                <td>
                                    <% if (review.product && review.product.name) { %>
                                        <strong><%= review.product.name %></strong>
                                    <% } else { %>
                                        <span class="text-muted">Product not found</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (review.user && review.user.name) { %>
                                        <%= review.user.name %>
                                    <% } else { %>
                                        <span class="text-muted">Anonymous</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="rating-stars">
                                        <% for(let i = 1; i <= 5; i++) { %>
                                            <i class="fas fa-star <%= i <= review.rating ? 'text-warning' : 'text-light' %>"></i>
                                        <% } %>
                                        <span class="ms-2"><%= review.rating %>/5</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="review-text" style="max-width: 300px;">
                                        <strong><%= review.title || 'No Title' %></strong>
                                        <p class="mb-0 text-muted small"><%= review.comment ? (review.comment.length > 100 ? review.comment.substring(0, 100) + '...' : review.comment) : 'No comment' %></p>
                                    </div>
                                </td>
                                <td>
                                    <%= new Date(review.createdAt).toLocaleDateString() %>
                                    <br>
                                    <small class="text-muted"><%= new Date(review.createdAt).toLocaleTimeString() %></small>
                                </td>
                                <td>
                                    <% if (review.isApproved) { %>
                                        <span class="badge bg-success">Approved</span>
                                    <% } else { %>
                                        <span class="badge bg-warning">Pending</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" 
                                                class="btn btn-info"
                                                data-bs-toggle="modal" 
                                                data-bs-target="#reviewModal<%= review._id %>"
                                                title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        
                                        <% if (!review.isApproved) { %>
                                            <form action="/admin/reviews/<%= review._id %>/approve" 
                                                  method="POST" 
                                                  class="d-inline"
                                                  onsubmit="return confirm('Approve this review?')">
                                                <button type="submit" class="btn btn-success" title="Approve">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <form action="/admin/reviews/<%= review._id %>/disapprove" 
                                                  method="POST" 
                                                  class="d-inline"
                                                  onsubmit="return confirm('Disapprove this review?')">
                                                <button type="submit" class="btn btn-warning" title="Disapprove">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                        
                                        <form action="/admin/reviews/<%= review._id %>/delete" 
                                              method="POST" 
                                              class="d-inline"
                                              onsubmit="return confirm('Delete this review?')">
                                            <button type="submit" class="btn btn-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                    
                                    <!-- Review Modal -->
                                    <div class="modal fade" id="reviewModal<%= review._id %>" tabindex="-1">
                                        <div class="modal-dialog modal-lg">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Review Details</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <h6>Customer Information</h6>
                                                            <p class="mb-1">
                                                                <strong>Name:</strong> 
                                                                <%= review.user && review.user.name ? review.user.name : 'Anonymous' %>
                                                            </p>
                                                            <% if (review.user && review.user.email) { %>
                                                                <p class="mb-1">
                                                                    <strong>Email:</strong> <%= review.user.email %>
                                                                </p>
                                                            <% } %>
                                                            <p class="mb-0">
                                                                <strong>Submitted:</strong> 
                                                                <%= new Date(review.createdAt).toLocaleString() %>
                                                            </p>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <h6>Product Information</h6>
                                                            <% if (review.product && review.product.name) { %>
                                                                <p class="mb-1">
                                                                    <strong>Product:</strong> <%= review.product.name %>
                                                                </p>
                                                                <a href="/products/<%= review.product.slug || '#' %>" 
                                                                   target="_blank" 
                                                                   class="btn btn-sm btn-outline-primary">
                                                                    View Product
                                                                </a>
                                                            <% } else { %>
                                                                <p class="text-muted">Product information not available</p>
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                    
                                                    <hr>
                                                    
                                                    <div class="mt-3">
                                                        <h6>Review Details</h6>
                                                        <div class="rating mb-2">
                                                            <strong>Rating:</strong>
                                                            <% for(let i = 1; i <= 5; i++) { %>
                                                                <i class="fas fa-star <%= i <= review.rating ? 'text-warning' : 'text-light' %>"></i>
                                                            <% } %>
                                                            <span class="ms-2"><%= review.rating %> out of 5</span>
                                                        </div>
                                                        
                                                        <% if (review.title) { %>
                                                            <p class="mb-1"><strong>Title:</strong> <%= review.title %></p>
                                                        <% } %>
                                                        
                                                        <div class="mb-3">
                                                            <strong>Comment:</strong>
                                                            <p class="mt-1 p-3 bg-light rounded"><%= review.comment || 'No comment provided' %></p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                    <form action="/admin/reviews/<%= review._id %>/delete" method="POST" class="d-inline">
                                                        <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this review?')">
                                                            <i class="fas fa-trash me-1"></i>Delete
                                                        </button>
                                                    </form>
                                                    <% if (!review.isApproved) { %>
                                                        <form action="/admin/reviews/<%= review._id %>/approve" method="POST" class="d-inline">
                                                            <button type="submit" class="btn btn-success" onclick="return confirm('Approve this review?')">
                                                                <i class="fas fa-check me-1"></i>Approve
                                                            </button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                
                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <% if (currentPageNum > 1) { %>
                            <li class="page-item">
                                <a class="page-link" href="?page=<%= currentPageNum-1 %>">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                        <% } %>
                        
                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= i === currentPageNum ? 'active' : '' %>">
                                <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                            </li>
                        <% } %>
                        
                        <% if (currentPageNum < totalPages) { %>
                            <li class="page-item">
                                <a class="page-link" href="?page=<%= currentPageNum+1 %>">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        <% } %>
                    </ul>
                </nav>
                <% } %>
            <% } else { %>
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-star fa-4x text-muted"></i>
                    </div>
                    <h4>No Reviews Yet</h4>
                    <p class="text-muted mb-4">There are no customer reviews to display.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Add CSS for stars -->
<style>
    .rating-stars {
        display: inline-flex;
        align-items: center;
    }
    .rating-stars .fa-star {
        font-size: 14px;
    }
</style>