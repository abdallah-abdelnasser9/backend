<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Manage Customers' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <h1 class="h3 mb-0">Manage Customers</h1>
            </div>
        </div>

        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">All Customers</h6>
            </div>
            <div class="card-body">
                <% if (customers && customers.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Joined</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% customers.forEach(customer => { %>
                                <tr>
                                    <td><%= customer.name %></td>
                                    <td><%= customer.email %></td>
                                    <td><%= customer.phone || 'N/A' %></td>
                                    <td><%= new Date(customer.createdAt).toLocaleDateString() %></td>
                                    <td>
                                        <span class="badge <%= customer.isActive ? 'bg-success' : 'bg-secondary' %>">
                                            <%= customer.isActive ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td>
                                        <a href="/admin/customers/<%= customer._id %>" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                        <form action="/admin/customers/<%= customer._id %>/toggle" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm <%= customer.isActive ? 'btn-warning' : 'btn-success' %>">
                                                <%= customer.isActive ? 'Deactivate' : 'Activate' %>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p>No customers found.</p>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>