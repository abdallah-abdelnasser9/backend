<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-comments me-2"></i>Customer Support Chat
            </h1>
            <p class="mb-0">Manage customer conversations in real-time</p>
        </div>
        <div class="badge bg-primary p-2">
            <i class="fas fa-envelope me-1"></i>
            <span id="unreadCount">0</span> unread
        </div>
    </div>

    <div class="row">
        <!-- User List -->
        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-users me-2"></i>Customers
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" id="userList">
                        <% if (users && users.length > 0) { %>
                            <% users.forEach(customer => { %>
                            <a href="/admin/chat/<%= customer.userId %>" 
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1"><%= customer.name %></h6>
                                    <p class="text-muted mb-0 small"><%= customer.email %></p>
                                    <small class="text-muted">
                                        <% if (customer.lastMessage) { %>
                                            <% if (customer.lastMessage.length > 25) { %>
                                                <%= customer.lastMessage.substring(0, 25) + '...' %>
                                            <% } else { %>
                                                <%= customer.lastMessage %>
                                            <% } %>
                                        <% } else { %>
                                            No messages
                                        <% } %>
                                    </small>
                                </div>
                                <div class="text-end">
                                    <% if (customer.unreadCount > 0) { %>
                                        <span class="badge bg-danger rounded-pill">
                                            <%= customer.unreadCount %>
                                        </span>
                                    <% } %>
                                    <div class="text-muted small">
                                        <% if (customer.lastMessageTime) { %>
                                            <%= new Date(customer.lastMessageTime).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                        <% } %>
                                    </div>
                                </div>
                            </a>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-4">
                                <i class="fas fa-comment-slash fa-2x text-muted mb-3"></i>
                                <p class="text-muted mb-0">No conversations yet</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chat Area -->
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header py-3 bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold">
                            <i class="fas fa-comment-dots me-2"></i>
                            <span id="currentChatUser">Select a customer to start chatting</span>
                        </h6>
                        <div id="adminConnectionStatus" class="badge bg-success">
                            <i class="fas fa-circle me-1"></i> Online
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Chat Messages -->
                    <div id="chatMessages" style="height: 400px; overflow-y: auto; padding: 15px; background-color: #f8f9fa;">
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-comments fa-3x mb-3"></i>
                            <h5>Welcome to Admin Chat</h5>
                            <p>Select a customer from the list to view and respond to their messages</p>
                        </div>
                    </div>
                    
                    <!-- Message Input -->
                    <div class="mt-3" id="chatInput" style="display: none;">
                        <div class="input-group">
                            <input type="text" id="messageInput" class="form-control" 
                                   placeholder="Type your message..." autocomplete="off">
                            <button type="button" id="sendButton" class="btn btn-primary">
                                <i class="fas fa-paper-plane"></i> Send
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div><!-- REAL-TIME JAVASCRIPT -->
<script>
// ========== GLOBAL VARIABLES ==========
let socket = null;
let userId = '<%= user ? user._id : "" %>';
let userName = '<%= user ? (user.name || user.email || "User") : "" %>';

// ========== HELPER FUNCTIONS (DEFINE FIRST) ==========

// Update connection status
function updateConnectionStatus(status, type) {
    const statusElem = document.getElementById('connectionStatus');
    if (statusElem) {
        const colors = {
            'success': 'bg-success',
            'danger': 'bg-danger', 
            'warning': 'bg-warning'
        };
        const icons = {
            'success': 'fa-check-circle',
            'danger': 'fa-times-circle',
            'warning': 'fa-exclamation-triangle'
        };
        
        statusElem.className = `badge ${colors[type] || 'bg-secondary'}`;
        statusElem.innerHTML = `<i class="fas ${icons[type] || 'fa-circle'} me-1"></i> ${status}`;
    }
}

// Setup send button with proper event handling
function setupSendButton() {
    const sendButton = document.getElementById('sendButton');
    const messageInput = document.getElementById('messageInput');
    
    if (!sendButton || !messageInput) {
        console.error('❌ Send button or message input not found!');
        return;
    }
    
    console.log('✅ Setting up send button');
    
    // Clear existing listeners by cloning
    const newSendButton = sendButton.cloneNode(true);
    sendButton.parentNode.replaceChild(newSendButton, sendButton);
    
    // Add click event
    newSendButton.addEventListener('click', sendMessage);
    
    // Add Enter key support
    messageInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            sendMessage();
        }
    });
    
    // Auto-focus
    setTimeout(() => {
        messageInput.focus();
    }, 100);
}

// Add message to UI
function addMessageToUI(msgData) {
    const chatMessages = document.getElementById('chatMessages');
    if (!chatMessages) {
        console.error('❌ Chat messages container not found!');
        return;
    }
    
    const isUser = msgData.senderType === 'user' || msgData.sender === userId;
    const time = msgData.createdAt ? 
                new Date(msgData.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : 
                '--:--';
    
    // Remove "no messages" placeholder if present
    const placeholder = chatMessages.querySelector('.text-center.text-muted');
    if (placeholder) {
        placeholder.remove();
    }
    
    const messageElement = document.createElement('div');
    messageElement.className = 'mb-3 message-animation';
    messageElement.dataset.messageId = msgData._id;
    messageElement.dataset.senderType = isUser ? 'user' : 'admin';
    
    let statusHTML = '';
    if (isUser) {
        if (msgData.isSending) {
            statusHTML = '<small class="text-light opacity-75"><i class="fas fa-spinner fa-spin me-1"></i> Sending...</small>';
        } else if (msgData.isRead) {
            statusHTML = '<small class="text-light opacity-75"><i class="fas fa-check-double me-1 text-info"></i> Read</small>';
        } else if (msgData.isDelivered) {
            statusHTML = '<small class="text-light opacity-75"><i class="fas fa-check-double me-1"></i> Delivered</small>';
        } else {
            statusHTML = '<small class="text-light opacity-75"><i class="fas fa-check me-1"></i> Sent</small>';
        }
    } else if (msgData.isRead) {
        statusHTML = '<small class="text-muted"><i class="fas fa-check-double me-1 text-info"></i> Read</small>';
    }
    
    messageElement.innerHTML = `
        <div class="d-flex ${isUser ? 'justify-content-end' : 'justify-content-start'}">
            <div class="${isUser ? 'bg-primary text-white' : 'bg-light'} p-3 rounded" style="max-width: 70%;">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <small class="${isUser ? 'text-light' : 'text-muted'} fw-bold">
                        ${isUser ? 
                            '<i class="fas fa-user me-1"></i> You' : 
                            '<i class="fas fa-user-shield me-1"></i> Support Agent'}
                    </small>
                    <small class="${isUser ? 'text-light' : 'text-muted'}">
                        ${time}
                    </small>
                </div>
                <p class="mb-1">${msgData.message}</p>
                ${statusHTML}
            </div>
        </div>
    `;
    
    chatMessages.appendChild(messageElement);
    
    // Scroll to bottom
    setTimeout(() => {
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }, 100);
}

// Update message ID
function updateMessageId(oldId, newId) {
    const messageElement = document.querySelector(`[data-message-id="${oldId}"]`);
    if (messageElement) {
        messageElement.dataset.messageId = newId;
        
        // Update status text
        const statusElement = messageElement.querySelector('.opacity-75, .text-muted');
        if (statusElement) {
            statusElement.innerHTML = '<i class="fas fa-check me-1"></i> Sent';
        }
    }
}

// Remove specific message
function removeMessage(messageId) {
    const messageElement = document.querySelector(`[data-message-id="${messageId}"]`);
    if (messageElement) {
        messageElement.remove();
    }
}

// Play notification sound
function playNotification() {
    try {
        const audioContext = new (window.AudioContext || window.webkitAudioContext)();
        const oscillator = audioContext.createOscillator();
        const gainNode = audioContext.createGain();
        
        oscillator.connect(gainNode);
        gainNode.connect(audioContext.destination);
        
        oscillator.frequency.value = 800;
        oscillator.type = 'sine';
        
        gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);
        
        oscillator.start(audioContext.currentTime);
        oscillator.stop(audioContext.currentTime + 0.3);
    } catch (e) {
        // Audio not supported
    }
}

// Send message function
function sendMessage() {
    const messageInput = document.getElementById('messageInput');
    const sendButton = document.getElementById('sendButton');
    const message = messageInput.value.trim();
    
    if (!message) {
        alert('Please enter a message');
        return;
    }
    
    console.log('📤 Attempting to send message:', message);
    
    // Disable inputs
    sendButton.disabled = true;
    messageInput.disabled = true;
    const originalButtonHTML = sendButton.innerHTML;
    sendButton.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Sending...';
    
    // Generate temp message ID
    const tempMessageId = 'temp-' + Date.now();
    
    // Add message to UI immediately (optimistic update)
    addMessageToUI({
        _id: tempMessageId,
        sender: userId,
        senderType: 'user',
        message: message,
        createdAt: new Date(),
        isSending: true
    });
    
    // Send to server
    fetch('/chat/send', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ 
            message: message
        })
    })
    .then(response => {
        console.log('Response status:', response.status);
        
        if (response.status === 401) {
            throw new Error('Please login to send messages');
        }
        
        if (!response.ok) {
            throw new Error('Network error: ' + response.status);
        }
        
        return response.json();
    })
    .then(data => {
        console.log('✅ Server response:', data);
        
        if (data.success) {
            // Clear input
            messageInput.value = '';
            
            // Update temp message with real ID
            updateMessageId(tempMessageId, data.chatId);
            
            // Send via socket for real-time (if socket exists)
            if (socket) {
                socket.emit('sendMessage', {
                    senderId: userId,
                    receiverId: 'admin',
                    message: message
                });
            }
        } else {
            // Show error and remove optimistic message
            removeMessage(tempMessageId);
            alert('Error: ' + (data.error || 'Failed to send message'));
        }
    })
    .catch(error => {
        console.error('❌ Send error:', error);
        removeMessage(tempMessageId);
        
        if (error.message.includes('login') || error.message.includes('401')) {
            alert('Please login to send messages');
            window.location.href = '/login';
        } else {
            alert('Failed to send message. Please try again.');
        }
    })
    .finally(() => {
        // Re-enable inputs
        sendButton.disabled = false;
        messageInput.disabled = false;
        sendButton.innerHTML = originalButtonHTML;
        messageInput.focus();
    });
}

// ========== MAIN INITIALIZATION ==========

// Debug: Check if user data is available
console.log('User chat loaded - User ID:', userId ? userId.substring(0, 10) + '...' : 'No user ID');

// Initialize when page loads
document.addEventListener('DOMContentLoaded', function() {
    console.log('✅ DOM fully loaded and parsed');
    
    // Setup send button FIRST
    setupSendButton();
    
    // Initialize Socket.io only if user is logged in AND socket.io is available
    if (userId && typeof io !== 'undefined') {
        try {
            socket = io();
            
            socket.on('connect', () => {
                console.log('✅ Socket connected:', socket.id);
                updateConnectionStatus('Connected', 'success');
                
                // Join user's room
                socket.emit('join', userId);
            });
            
            socket.on('disconnect', () => {
                console.log('❌ Socket disconnected');
                updateConnectionStatus('Disconnected', 'danger');
            });
            
            socket.on('connect_error', (error) => {
                console.error('Socket error:', error);
                updateConnectionStatus('Connection Error', 'warning');
            });
            
            // Handle incoming messages
            socket.on('receiveMessage', function(data) {
                console.log('📩 Received message via socket:', data);
                
                // Check if message is for this user
                if (data.receiver === userId) {
                    console.log('✅ Message is for current user');
                    
                    addMessageToUI({
                        _id: data._id,
                        sender: 'admin',
                        senderType: 'admin',
                        message: data.message,
                        createdAt: data.createdAt || new Date(),
                        isRead: false
                    });
                    
                    playNotification();
                }
            });
            
            // Message sent confirmation
            socket.on('messageSent', function(data) {
                console.log('✅ Message sent confirmation:', data);
                // This would update message status if needed
            });
            
        } catch (e) {
            console.error('Socket initialization error:', e);
        }
    } else {
        console.warn('⚠️ Socket.io not available or user not logged in');
        if (!userId) {
            console.error('CRITICAL: User ID not found in template');
            
            // Show error message
            const chatContainer = document.getElementById('chatMessages');
            if (chatContainer) {
                chatContainer.innerHTML = `
                    <div class="alert alert-danger">
                        <h5>Authentication Required</h5>
                        <p>Please <a href="/login">login</a> to use the chat.</p>
                    </div>
                `;
                if (messageInput) messageInput.disabled = true;
                if (sendButton) sendButton.disabled = true;
            }
        }
    }
});

</script>

<style>
.list-group-item.active {
    background-color: #e3f2fd;
    border-color: #2196f3;
    font-weight: bold;
}

#chatMessages {
    scroll-behavior: smooth;
}

#chatMessages::-webkit-scrollbar {
    width: 8px;
}

#chatMessages::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 4px;
}

#chatMessages::-webkit-scrollbar-thumb {
    background: #888;
    border-radius: 4px;
}

#chatMessages::-webkit-scrollbar-thumb:hover {
    background: #555;
}

.message-animation {
    animation: slideIn 0.3s ease;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.bg-light {
    border-left: 4px solid #6c757d;
    position: relative;
}

.bg-primary {
    border-right: 4px solid #0d6efd;
    position: relative;
}

/* Customer message indicator */
.bg-light::before {
    content: "Customer";
    position: absolute;
    top: -8px;
    left: 10px;
    font-size: 10px;
    color: #6c757d;
    font-weight: bold;
    background: white;
    padding: 0 5px;
    border-radius: 3px;
}

/* Admin message indicator */
.bg-primary::before {
    content: "You";
    position: absolute;
    top: -8px;
    right: 10px;
    font-size: 10px;
    color: #0d6efd;
    font-weight: bold;
    background: white;
    padding: 0 5px;
    border-radius: 3px;
}
</style>