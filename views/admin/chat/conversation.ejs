<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-comments me-2"></i>Chat with <%= chatUser.name %>
            </h1>
            <p class="mb-0 text-muted">
                <i class="fas fa-envelope me-1"></i><%= chatUser.email %>
            </p>
        </div>
        <div>
            <a href="/admin/chat" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i> Back to Chats
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3 bg-primary text-white">
                    <h6 class="m-0 font-weight-bold">
                        <i class="fas fa-user me-2"></i><%= chatUser.name %>
                    </h6>
                </div>
                
                <div class="card-body p-0">
                    <div id="chatMessages" style="height: 500px; overflow-y: auto; padding: 20px; background-color: #f8f9fa;">
                        <% if (messages && messages.length > 0) { %>
                            <% messages.forEach(msg => { 
                                const isAdmin = msg.sender === 'admin';
                                const time = new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                            %>
                            <div class="mb-2">
                                <div class="d-flex <%= isAdmin ? 'justify-content-end' : 'justify-content-start' %>">
                                    <div class="<%= isAdmin ? 'bg-primary text-white' : 'bg-light' %> p-2 rounded" style="max-width: 70%;">
                                        <p class="mb-1"><%= msg.message %></p>
                                        <small class="<%= isAdmin ? 'opacity-75' : 'text-muted' %>">
                                            <%= time %>
                                            <% if (isAdmin) { %>
                                                <i class="fas fa-check ms-1"></i>
                                            <% } %>
                                        </small>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center text-muted py-5">
                                <i class="fas fa-comment-slash fa-3x mb-3"></i>
                                <h5>No messages yet</h5>
                                <p>Start the conversation with <%= chatUser.name %></p>
                            </div>
                        <% } %>
                    </div>
                    
                    <div class="p-3 border-top">
                        <div class="input-group">
                            <input type="text" id="messageInput" class="form-control" 
                                   placeholder="Type your message here..." autocomplete="off"
                                   autofocus>
                            <button type="button" id="sendButton" class="btn btn-primary px-4">
                                <i class="fas fa-paper-plane me-1"></i> Send
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SIMPLE JAVASCRIPT FOR CONVERSATION PAGE -->
<script>
window.addEventListener('load', function() {
    console.log('✅ Admin conversation page loaded');
    
    const chatUserId = '<%= chatUser._id %>';
    const adminId = 'admin';
    
    // Initialize socket
    let socket;
    if (typeof io !== 'undefined') {
        try {
            socket = io();
            socket.emit('join', adminId);
            console.log('✅ Socket.io connected');
        } catch (e) {
            console.log('Socket error:', e);
        }
    }
    
    // Scroll to bottom
    const chatMessages = document.getElementById('chatMessages');
    chatMessages.scrollTop = chatMessages.scrollHeight;
    
    // Setup send button
    const sendButton = document.getElementById('sendButton');
    const messageInput = document.getElementById('messageInput');
    
    if (sendButton && messageInput) {
        // Clone to remove existing listeners
        const newSendButton = sendButton.cloneNode(true);
        sendButton.parentNode.replaceChild(newSendButton, sendButton);
        
        const newMessageInput = messageInput.cloneNode(true);
        messageInput.parentNode.replaceChild(newMessageInput, messageInput);
        
        // Add click event
        newSendButton.addEventListener('click', function(e) {
            e.preventDefault();
            sendMessage();
        });
        
        // Add Enter key support
        newMessageInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                sendMessage();
            }
        });
        
        // Focus input
        setTimeout(() => {
            newMessageInput.focus();
        }, 100);
    }
    
    // Send message function
    function sendMessage() {
        const messageInput = document.getElementById('messageInput');
        const sendButton = document.getElementById('sendButton');
        const message = messageInput.value.trim();
        
        if (!message) {
            alert('Please enter a message');
            return;
        }
        
        console.log('Sending to:', chatUserId, 'Message:', message);
        
        // Disable inputs
        sendButton.disabled = true;
        messageInput.disabled = true;
        const originalButtonHTML = sendButton.innerHTML;
        sendButton.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Sending...';
        
        // Add to UI immediately
        const time = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
        const messageElement = document.createElement('div');
        messageElement.className = 'mb-2';
        messageElement.innerHTML = `
            <div class="d-flex justify-content-end">
                <div class="bg-primary text-white p-2 rounded" style="max-width: 70%;">
                    <p class="mb-1">${message}</p>
                    <small class="opacity-75">
                        ${time} <i class="fas fa-spinner fa-spin ms-1"></i>
                    </small>
                </div>
            </div>
        `;
        
        chatMessages.appendChild(messageElement);
        chatMessages.scrollTop = chatMessages.scrollHeight;
        
        // Send to server
        fetch('/admin/chat/send', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                receiverId: chatUserId,
                message: message
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Update UI
                const spinner = messageElement.querySelector('.fa-spinner');
                if (spinner) {
                    spinner.className = 'fas fa-check ms-1';
                }
                
                // Clear input
                messageInput.value = '';
                
                // Send via socket
                if (socket) {
                    socket.emit('sendMessage', {
                        senderId: adminId,
                        receiverId: chatUserId,
                        message: message
                    });
                }
            } else {
                messageElement.remove();
                alert('Error: ' + data.error);
            }
        })
        .catch(error => {
            console.error('Send error:', error);
            messageElement.remove();
            alert('Failed to send message');
        })
        .finally(() => {
            sendButton.disabled = false;
            messageInput.disabled = false;
            sendButton.innerHTML = originalButtonHTML;
            messageInput.focus();
        });
    }
    
    // Receive messages
    if (socket) {
        socket.on('receiveMessage', function(data) {
            if (data.sender === chatUserId) {
                const time = new Date(data.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                const messageElement = document.createElement('div');
                messageElement.className = 'mb-2';
                messageElement.innerHTML = `
                    <div class="d-flex justify-content-start">
                        <div class="bg-light p-2 rounded" style="max-width: 70%;">
                            <p class="mb-1">${data.message}</p>
                            <small class="text-muted">${time}</small>
                        </div>
                    </div>
                `;
                
                chatMessages.appendChild(messageElement);
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }
        });
    }
});
</script>