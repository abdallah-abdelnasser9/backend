<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="fas fa-comments"></i> Customer Support Dashboard
                    </h4>
                    <a href="/admin/dashboard" class="btn btn-light btn-sm">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>
            <div class="card-body">
                <% if (users && users.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Customer</th>
                                    <th>Last Message</th>
                                    <th>Unread Messages</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(userChat => { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <% if (userChat.user.avatar) { %>
                                                <img src="<%= userChat.user.avatar %>" 
                                                     class="rounded-circle me-2" 
                                                     style="width: 40px; height: 40px; object-fit: cover;">
                                            <% } else { %>
                                                <div class="rounded-circle bg-secondary me-2 d-flex align-items-center justify-content-center" 
                                                     style="width: 40px; height: 40px;">
                                                    <i class="fas fa-user text-white"></i>
                                                </div>
                                            <% } %>
                                            <div>
                                                <strong><%= userChat.user.name %></strong><br>
                                                <small class="text-muted"><%= userChat.user.email %></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <% if (userChat.lastMessage) { %>
                                            <small><%= new Date(userChat.lastMessage).toLocaleString() %></small>
                                        <% } else { %>
                                            <small class="text-muted">No messages yet</small>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (userChat.unreadCount > 0) { %>
                                            <span class="badge bg-danger rounded-pill">
                                                <%= userChat.unreadCount %> unread
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-success rounded-pill">All read</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <a href="/chat/admin/<%= userChat.user._id %>" 
                                           class="btn btn-primary btn-sm">
                                            <i class="fas fa-comment"></i> Open Chat
                                        </a>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="fas fa-comments fa-3x text-muted mb-3"></i>
                        <h4>No customer chats yet</h4>
                        <p class="text-muted">When customers send messages, they will appear here.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
// Auto refresh every 30 seconds
setInterval(() => {
    location.reload();
}, 30000);
</script>