<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="mb-0">
                            <i class="fas fa-comments"></i> Chat with <%= userName %>
                        </h4>
                        <small><%= user.email %></small>
                    </div>
                    <div>
                        <a href="/chat/admin" class="btn btn-light btn-sm me-2">
                            <i class="fas fa-arrow-left"></i> Back
                        </a>
                        <a href="/admin/customers/<%= userId %>" class="btn btn-info btn-sm">
                            <i class="fas fa-user"></i> View Profile
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <!-- Chat Messages -->
                <div class="chat-messages" id="chatMessages" 
                     style="height: 500px; overflow-y: auto; padding: 15px; background-color: #f8f9fa;">
                    
                    <% if (chats && chats.length > 0) { %>
                        <% chats.forEach(chat => { %>
                            <% if (chat.sender.toString() === adminId) { %>
                                <!-- Admin Message (sent) -->
                                <div class="message admin-message mb-3 text-end">
                                    <div class="message-content bg-primary text-white p-3 rounded" 
                                         style="max-width: 70%; display: inline-block;">
                                        <p class="mb-1"><%= chat.message %></p>
                                        <small class="opacity-75">
                                            <%= new Date(chat.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                        </small>
                                    </div>
                                </div>
                            <% } else { %>
                                <!-- User Message (received) -->
                                <div class="message user-message mb-3">
                                    <div class="message-content bg-light p-3 rounded" 
                                         style="max-width: 70%; display: inline-block;">
                                        <p class="mb-1"><%= chat.message %></p>
                                        <small class="text-muted">
                                            <%= new Date(chat.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                        </small>
                                    </div>
                                </div>
                            <% } %>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-comment-alt fa-2x mb-2"></i>
                            <p>No messages yet. Start the conversation.</p>
                        </div>
                    <% } %>
                </div>
                
                <!-- Message Input -->
                <div class="chat-input mt-3">
                    <form id="chatForm">
                        <div class="input-group">
                            <input type="hidden" id="receiverId" value="<%= userId %>">
                            <input type="text" id="messageInput" class="form-control" 
                                   placeholder="Type your message..." autocomplete="off">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane"></i> Send
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
$(document).ready(function() {
    const socket = io();
    const adminId = '<%= adminId %>';
    const userId = '<%= userId %>';
    const receiverId = '<%= userId %>';
    
    // Join admin room
    socket.emit('join', adminId);
    
    // Scroll to bottom of chat
    const chatMessages = $('#chatMessages');
    chatMessages.scrollTop(chatMessages[0].scrollHeight);
    
    // Send message
    $('#chatForm').submit(function(e) {
        e.preventDefault();
        
        const message = $('#messageInput').val().trim();
        if (!message) return;
        
        // Send via socket
        socket.emit('sendMessage', {
            senderId: adminId,
            receiverId: receiverId,
            message: message,
            isAdmin: true
        });
        
        // Also send via AJAX for database storage
        $.ajax({
            url: '/chat/send',
            method: 'POST',
            data: { 
                receiverId: receiverId,
                message: message
            },
            success: function(response) {
                if (response.success) {
                    // Add message to UI
                    const time = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                    const messageHtml = `
                        <div class="message admin-message mb-3 text-end">
                            <div class="message-content bg-primary text-white p-3 rounded" 
                                 style="max-width: 70%; display: inline-block;">
                                <p class="mb-1">${message}</p>
                                <small class="opacity-75">${time}</small>
                            </div>
                        </div>`;
                    
                    $('#chatMessages').append(messageHtml);
                    $('#messageInput').val('');
                    chatMessages.scrollTop(chatMessages[0].scrollHeight);
                }
            }
        });
    });
    
    // Receive message
    socket.on('receiveMessage', function(data) {
        if (data.senderId === userId) {
            const time = new Date(data.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            const messageHtml = `
                <div class="message user-message mb-3">
                    <div class="message-content bg-light p-3 rounded" 
                         style="max-width: 70%; display: inline-block;">
                        <p class="mb-1">${data.message}</p>
                        <small class="text-muted">${time}</small>
                    </div>
                </div>`;
            
            $('#chatMessages').append(messageHtml);
            chatMessages.scrollTop(chatMessages[0].scrollHeight);
            
            // Play notification sound
            const audio = new Audio('/sound/notification.mp3');
            audio.play().catch(e => console.log('Audio play failed:', e));
        }
    });
    
    // Auto-refresh chat every 10 seconds
    setInterval(function() {
        $.ajax({
            url: '/chat/history/' + userId,
            method: 'GET',
            success: function(response) {
                if (response.success) {
                    // Could update chat if needed
                }
            }
        });
    }, 10000);
});
</script>