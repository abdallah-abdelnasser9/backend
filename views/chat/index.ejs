<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <!-- Connection Status -->
            <div class="alert alert-info mb-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">Customer Support Chat</h5>
                        <p class="mb-0 small">You are chatting with our support team</p>
                    </div>
                    <div>
                        <span id="connectionStatus" class="badge bg-success">
                            <i class="fas fa-circle me-1"></i> Connected
                        </span>
                    </div>
                </div>
            </div>

            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-headset me-2"></i>Customer Support
                        <small class="float-end">
                            <i class="fas fa-user me-1"></i> 
                            <%= user ? (user.name || user.email || 'User') : 'Guest' %>
                        </small>
                    </h5>
                </div>
                
                <!-- Chat Messages -->
                <div class="card-body p-0">
                    <div id="chatMessages" style="height: 400px; overflow-y: auto; padding: 20px; background-color: #f8f9fa;">
                        <% if (messages && Array.isArray(messages) && messages.length > 0) { %>
                            <% messages.forEach(msg => { 
                                // Simple sender detection - if sender matches user._id, it's the user
                                const isUser = user && user._id && msg.sender && 
                                              (msg.sender.toString() === user._id.toString() || 
                                               msg.senderType === 'user');
                                const senderName = isUser ? 'You' : 'Support Agent';
                                const time = msg.createdAt ? new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : '--:--';
                                const date = msg.createdAt ? new Date(msg.createdAt).toLocaleDateString() : '--/--/----';
                            %>
                            <div class="mb-3" data-message-id="<%= msg._id || 'temp' %>" data-sender-type="<%= isUser ? 'user' : 'admin' %>">
                                <div class="d-flex <%= isUser ? 'justify-content-end' : 'justify-content-start' %>">
                                    <div class="<%= isUser ? 'bg-primary text-white' : 'bg-light' %> p-3 rounded" style="max-width: 70%;">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <small class="<%= isUser ? 'text-light' : 'text-muted' %> fw-bold">
                                                <% if (isUser) { %>
                                                    <i class="fas fa-user me-1"></i> You
                                                <% } else { %>
                                                    <i class="fas fa-user-shield me-1"></i> Support Agent
                                                <% } %>
                                            </small>
                                            <small class="<%= isUser ? 'text-light' : 'text-muted' %>">
                                                <%= time %>
                                            </small>
                                        </div>
                                        <p class="mb-1"><%= msg.message %></p>
                                        <% if (isUser) { %>
                                            <small class="text-light opacity-75">
                                                <% if (msg.isRead) { %>
                                                    <i class="fas fa-check-double me-1 text-info"></i> Read
                                                <% } else if (msg.isDelivered) { %>
                                                    <i class="fas fa-check-double me-1"></i> Delivered
                                                <% } else { %>
                                                    <i class="fas fa-check me-1"></i> Sent
                                                <% } %>
                                            </small>
                                        <% } else if (msg.isRead) { %>
                                            <small class="text-muted">
                                                <i class="fas fa-check-double me-1 text-info"></i> Read
                                            </small>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center text-muted py-5">
                                <i class="fas fa-comments fa-3x mb-3"></i>
                                <h5>Welcome to Support Chat</h5>
                                <p>Our team is here to help you. Start by sending a message!</p>
                            </div>
                        <% } %>
                    </div>
                    
                    <!-- Message Input -->
                    <div class="p-3 border-top">
                        <div class="input-group">
                            <input type="text" id="messageInput" class="form-control" 
                                   placeholder="Type your message here..." autocomplete="off">
                            <button type="button" id="sendButton" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-1"></i> Send
                            </button>
                        </div>
                        <small class="text-muted mt-1 d-block">
                            Press Enter or click Send
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
// ========== GLOBAL VARIABLES ==========
let socket = null;
const userId = '<%= user ? user._id : "" %>';

// ========== HELPER FUNCTIONS (DEFINED FIRST) ==========

// Update connection status
function updateConnectionStatus(status, type) {
    const statusElem = document.getElementById('connectionStatus');
    if (statusElem) {
        const colors = {
            'success': 'bg-success',
            'danger': 'bg-danger', 
            'warning': 'bg-warning'
        };
        const icons = {
            'success': 'fa-check-circle',
            'danger': 'fa-times-circle',
            'warning': 'fa-exclamation-triangle'
        };
        
        statusElem.className = `badge ${colors[type] || 'bg-secondary'}`;
        statusElem.innerHTML = `<i class="fas ${icons[type] || 'fa-circle'} me-1"></i> ${status}`;
    }
}

// Setup send button with proper event handling
function setupSendButton() {
    const sendButton = document.getElementById('sendButton');
    const messageInput = document.getElementById('messageInput');
    
    if (!sendButton || !messageInput) {
        console.error('❌ Send button or message input not found!');
        return;
    }
    
    console.log('✅ Setting up send button');
    
    // Remove existing listeners by cloning
    const newSendButton = sendButton.cloneNode(true);
    sendButton.parentNode.replaceChild(newSendButton, sendButton);
    
    // Add click event
    newSendButton.addEventListener('click', sendMessage);
    
    // Add Enter key support
    messageInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            sendMessage();
        }
    });
    
    // Auto-focus
    setTimeout(() => {
        messageInput.focus();
    }, 100);
}

// Add message to UI
function addMessageToUI(msgData) {
    const chatMessages = document.getElementById('chatMessages');
    if (!chatMessages) {
        console.error('❌ Chat messages container not found!');
        return;
    }
    
    const isUser = msgData.senderType === 'user' || msgData.sender === userId;
    const time = msgData.createdAt ? 
                new Date(msgData.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : 
                '--:--';
    
    // Remove "no messages" placeholder if present
    const placeholder = chatMessages.querySelector('.text-center.text-muted');
    if (placeholder) {
        placeholder.remove();
    }
    
    const messageElement = document.createElement('div');
    messageElement.className = 'mb-3 message-animation';
    messageElement.dataset.messageId = msgData._id;
    messageElement.dataset.senderType = isUser ? 'user' : 'admin';
    
    let statusHTML = '';
    if (isUser) {
        if (msgData.isSending) {
            statusHTML = '<small class="text-light opacity-75"><i class="fas fa-spinner fa-spin me-1"></i> Sending...</small>';
        } else if (msgData.isRead) {
            statusHTML = '<small class="text-light opacity-75"><i class="fas fa-check-double me-1 text-info"></i> Read</small>';
        } else if (msgData.isDelivered) {
            statusHTML = '<small class="text-light opacity-75"><i class="fas fa-check-double me-1"></i> Delivered</small>';
        } else {
            statusHTML = '<small class="text-light opacity-75"><i class="fas fa-check me-1"></i> Sent</small>';
        }
    } else if (msgData.isRead) {
        statusHTML = '<small class="text-muted"><i class="fas fa-check-double me-1 text-info"></i> Read</small>';
    }
    
    messageElement.innerHTML = `
        <div class="d-flex ${isUser ? 'justify-content-end' : 'justify-content-start'}">
            <div class="${isUser ? 'bg-primary text-white' : 'bg-light'} p-3 rounded" style="max-width: 70%;">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <small class="${isUser ? 'text-light' : 'text-muted'} fw-bold">
                        ${isUser ? 
                            '<i class="fas fa-user me-1"></i> You' : 
                            '<i class="fas fa-user-shield me-1"></i> Support Agent'}
                    </small>
                    <small class="${isUser ? 'text-light' : 'text-muted'}">
                        ${time}
                    </small>
                </div>
                <p class="mb-1">${msgData.message}</p>
                ${statusHTML}
            </div>
        </div>
    `;
    
    chatMessages.appendChild(messageElement);
    
    // Scroll to bottom
    setTimeout(() => {
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }, 100);
}   
// Update message ID
function updateMessageId(oldId, newId) {
    const messageElement = document.querySelector(`[data-message-id="${oldId}"]`);
    if (messageElement) {
        messageElement.dataset.messageId = newId;
        
        // Update status text
        const statusElement = messageElement.querySelector('.opacity-75, .text-muted');
        if (statusElement) {
            statusElement.innerHTML = '<i class="fas fa-check me-1"></i> Sent';
        }
    }
}

// Remove specific message
function removeMessage(messageId) {
    const messageElement = document.querySelector(`[data-message-id="${messageId}"]`);
    if (messageElement) {
        messageElement.remove();
    }
}

// Play notification sound
function playNotification() {
    try {
        const audio = new Audio('data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEAQB8AAEAfAAABAAgAZGF0YQ');
        audio.play();
    } catch (e) {
        // Audio not supported
        console.log('Notification sound not supported');
    }
}

// Send message function
function sendMessage() {
    const messageInput = document.getElementById('messageInput');
    const sendButton = document.getElementById('sendButton');
    const message = messageInput.value.trim();
    
    if (!message) {
        alert('Please enter a message');
        return;
    }
    
    console.log('📤 User attempting to send message:', message);
    
    // Disable inputs
    sendButton.disabled = true;
    messageInput.disabled = true;
    const originalButtonHTML = sendButton.innerHTML;
    sendButton.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Sending...';
    
    // Generate temp message ID
    const tempMessageId = 'temp-' + Date.now();
    
    // Add message to UI immediately (optimistic update)
    addMessageToUI({
        _id: tempMessageId,
        sender: userId,
        senderType: 'user',
        message: message,
        createdAt: new Date(),
        isSending: true
    });
    
    // Send to server
    fetch('/chat/send', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ 
            message: message
        })
    })
    .then(response => {
        console.log('Response status:', response.status);
        
        if (response.status === 401) {
            throw new Error('Please login to send messages');
        }
        
        if (!response.ok) {
            throw new Error('Network error: ' + response.status);
        }
        
        return response.json();
    })
    .then(data => {
        console.log('✅ Server response:', data);
        
        if (data.success) {
            // Clear input
            messageInput.value = '';
            
            // Update temp message with real ID
            updateMessageId(tempMessageId, data.chatId);
            
            // Send via socket for real-time
            if (socket) {
                socket.emit('sendMessage', {
                    senderId: userId,
                    receiverId: 'admin',
                    message: message
                });
            }
        } else {
            removeMessage(tempMessageId);
            alert('Error: ' + (data.error || 'Failed to send message'));
        }
    })
    .catch(error => {
        console.error('❌ Send error:', error);
        removeMessage(tempMessageId);
        alert('Failed to send message: ' + error.message);
    })
    .finally(() => {
        sendButton.disabled = false;
        messageInput.disabled = false;
        sendButton.innerHTML = originalButtonHTML;
        messageInput.focus();
    });
}

// ========== MAIN INITIALIZATION ==========

// Initialize when page loads
document.addEventListener('DOMContentLoaded', function() {
    console.log('✅ User chat loaded');
    console.log('User ID:', userId ? userId.substring(0, 10) + '...' : 'No user ID');
    
    // Setup send button FIRST
    setupSendButton();
    
    // Initialize Socket.io only if user is logged in
    if (userId && typeof io !== 'undefined') {
        try {
            socket = io();
            
            socket.on('connect', () => {
                console.log('✅ Socket connected:', socket.id);
                updateConnectionStatus('Connected', 'success');
                
                // Join user's room
                socket.emit('join', userId);
            });
            
            socket.on('disconnect', () => {
                console.log('❌ Socket disconnected');
                updateConnectionStatus('Disconnected', 'danger');
            });
            
            socket.on('connect_error', (error) => {
                console.error('Socket error:', error);
                updateConnectionStatus('Connection Error', 'warning');
            });
            
            // Handle incoming messages
            socket.on('receiveMessage', function(data) {
                console.log('📩 Received message via socket:', data);
                
                // Check if message is for this user
                if (data.receiver === userId) {
                    console.log('✅ Message is for current user');
                    
                    addMessageToUI({
                        _id: data._id,
                        sender: 'admin',
                        senderType: 'admin',
                        message: data.message,
                        createdAt: data.createdAt || new Date(),
                        isRead: false
                    });
                    
                    // Mark as read
                    if (socket) {
                        socket.emit('markAsRead', {
                            messageId: data._id,
                            senderId: 'admin',
                            receiverId: userId
                        });
                    }
                    
                    playNotification();
                }
            });
            
            // Message sent confirmation
            socket.on('messageSent', function(data) {
                console.log('✅ Message sent confirmation:', data);
                updateMessageId('temp-' + data.messageId, data.messageId);
            });
            
            // Message read confirmation
            socket.on('messageRead', function(data) {
                console.log('📖 Message read confirmation:', data);
                const messageElement = document.querySelector(`[data-message-id="${data.messageId}"]`);
                if (messageElement) {
                    const statusElement = messageElement.querySelector('.opacity-75, .text-muted');
                    if (statusElement) {
                        statusElement.innerHTML = '<i class="fas fa-check-double me-1 text-info"></i> Read';
                    }
                }
            });
            
        } catch (e) {
            console.error('Socket initialization error:', e);
        }
    } else {
        console.warn('⚠️ User not logged in or Socket.io not available');
        
        // Show error message if no user ID
        if (!userId) {
            const chatContainer = document.getElementById('chatMessages');
            if (chatContainer) {
                chatContainer.innerHTML = `
                    <div class="alert alert-danger">
                        <h5>Authentication Required</h5>
                        <p>Please <a href="/login">login</a> to use the chat.</p>
                    </div>
                `;
                document.getElementById('messageInput').disabled = true;
                document.getElementById('sendButton').disabled = true;
            }
        }
    }
});
</script>
<style>
#chatMessages {
    scroll-behavior: smooth;
}

#chatMessages::-webkit-scrollbar {
    width: 8px;
}

#chatMessages::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 4px;
}

#chatMessages::-webkit-scrollbar-thumb {
    background: #888;
    border-radius: 4px;
}

#chatMessages::-webkit-scrollbar-thumb:hover {
    background: #555;
}

.message-animation {
    animation: slideIn 0.3s ease;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.bg-light {
    border-left: 4px solid #6c757d;
}

.bg-primary {
    border-right: 4px solid #0d6efd;
}

#connectionStatus {
    transition: all 0.3s ease;
}

#sendButton:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.fa-spinner {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}
</style>