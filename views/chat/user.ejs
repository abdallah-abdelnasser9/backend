<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-headset me-2"></i>Customer Support
                        </h5>
                        <span class="badge bg-light text-primary" id="statusBadge">
                            <i class="fas fa-circle me-1"></i> Online
                        </span>
                    </div>
                </div>
                
                <!-- Chat Messages -->
                <div class="card-body p-0">
                    <div class="chat-messages" id="chatMessages" 
                         style="height: 500px; overflow-y: auto; padding: 20px; background-color: #f8f9fa;">
                        
                        <% if (messages && messages.length > 0) { %>
                            <% messages.forEach(msg => { 
                                const isUser = msg.sender.toString() === user._id.toString();
                                const time = new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                            %>
                            <div class="message mb-3">
                                <div class="d-flex <%= isUser ? 'justify-content-end' : '' %>">
                                    <div class="message-content <%= isUser ? 'bg-primary text-white' : 'bg-light' %> 
                                             p-3 rounded" style="max-width: 70%;">
                                        <p class="mb-1"><%= msg.message %></p>
                                        <small class="<%= isUser ? 'opacity-75' : 'text-muted' %>">
                                            <%= time %>
                                            <% if (isUser) { %>
                                                <i class="fas fa-check ms-1"></i>
                                            <% } else if (msg.isRead) { %>
                                                <i class="fas fa-check-double ms-1 text-info"></i>
                                            <% } %>
                                        </small>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center text-muted py-5">
                                <i class="fas fa-comments fa-3x mb-3"></i>
                                <h5>Welcome to Support Chat</h5>
                                <p>Our team is here to help you. Start by sending a message!</p>
                            </div>
                        <% } %>
                    </div>
                    
                    <!-- Message Input -->
                    <div class="chat-input p-3 border-top">
                        <form id="chatForm">
                            <div class="input-group">
                                <input type="text" id="messageInput" class="form-control" 
                                       placeholder="Type your message here..." autocomplete="off"
                                       autofocus>
                                <button type="submit" class="btn btn-primary px-4">
                                    <i class="fas fa-paper-plane me-1"></i> Send
                                </button>
                            </div>
                            <small class="text-muted mt-1 d-block">
                                Press Enter to send, Shift+Enter for new line
                            </small>
                        </form>
                    </div>
                </div>
            </div>
            
            <div class="card mt-3 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="fas fa-info-circle me-2 text-info"></i>Support Information
                    </h6>
                    <ul class="list-unstyled mb-0">
                        <li><i class="fas fa-clock me-2 text-muted"></i> Support hours: 24/7</li>
                        <li><i class="fas fa-reply me-2 text-muted"></i> Average response time: 5-10 minutes</li>
                        <li><i class="fas fa-shield-alt me-2 text-muted"></i> Your conversations are private and secure</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- JavaScript -->
<script>
$(document).ready(function() {
    const socket = io();
    const userId = '<%= user._id %>';
    
    // Join user room
    socket.emit('join', userId);
    console.log('User joined chat room:', userId);
    
    // Scroll to bottom on load
    const chatMessages = $('#chatMessages');
    chatMessages.scrollTop(chatMessages[0].scrollHeight);
    
    // Send message
    $('#chatForm').submit(async function(e) {
        e.preventDefault();
        
        const message = $('#messageInput').val().trim();
        if (!message) return;
        
        console.log('Sending message to admin');
        
        try {
            // Send via AJAX
            const response = await $.ajax({
                url: '/chat/send',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    message: message
                })
            });
            
            if (response.success) {
                // Also send via socket
                socket.emit('sendMessage', {
                    senderId: userId,
                    receiverId: 'admin',
                    message: message,
                    isAdmin: false
                });
                
                // Add message to UI
                const time = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                const messageHtml = `
                    <div class="message mb-3">
                        <div class="d-flex justify-content-end">
                            <div class="message-content bg-primary text-white p-3 rounded" style="max-width: 70%;">
                                <p class="mb-1">${message}</p>
                                <small class="opacity-75">
                                    ${time} <i class="fas fa-check ms-1"></i>
                                </small>
                            </div>
                        </div>
                    </div>`;
                
                $('#chatMessages').append(messageHtml);
                $('#messageInput').val('');
                
                // Scroll to bottom
                chatMessages.scrollTop(chatMessages[0].scrollHeight);
            } else {
                alert('Error: ' + response.error);
            }
        } catch (error) {
            console.error('Send error:', error);
            alert('Error sending message: ' + error.responseJSON?.error || error.statusText);
        }
    });
    
    // Receive new message from admin
    socket.on('receiveMessage', function(data) {
        console.log('Received message from admin:', data);
        
        if (data.sender === 'admin' && data.receiver === userId) {
            const time = new Date(data.createdAt || new Date()).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            const messageHtml = `
                <div class="message mb-3">
                    <div class="d-flex">
                        <div class="message-content bg-light p-3 rounded" style="max-width: 70%;">
                            <p class="mb-1">${data.message}</p>
                            <small class="text-muted">
                                ${time} <i class="fas fa-user-shield ms-1"></i>
                            </small>
                        </div>
                    </div>
                </div>`;
            
            $('#chatMessages').append(messageHtml);
            
            // Scroll to bottom
            chatMessages.scrollTop(chatMessages[0].scrollHeight);
            
            // Play notification sound
            playNotificationSound();
        }
    });
    
    // Handle typing indicator
    let typingTimeout;
    $('#messageInput').on('input', function() {
        clearTimeout(typingTimeout);
        socket.emit('typing', {
            userId: userId,
            receiverId: 'admin',
            isTyping: true
        });
        
        typingTimeout = setTimeout(() => {
            socket.emit('typing', {
                userId: userId,
                receiverId: 'admin',
                isTyping: false
            });
        }, 1000);
    });
    
    // Admin is typing
    socket.on('adminTyping', function(data) {
        if (data.isTyping) {
            $('#statusBadge').html('<i class="fas fa-pencil-alt me-1"></i> Admin is typing...');
        } else {
            $('#statusBadge').html('<i class="fas fa-circle me-1"></i> Online');
        }
    });
    
    // Update unread count
    socket.on('unreadCountUpdate', function(count) {
        // Update badge in navbar if exists
        const unreadBadge = $('#unreadCount');
        if (unreadBadge.length) {
            unreadBadge.text(count).toggleClass('d-none', count === 0);
        }
    });
    
    // Play notification sound
    function playNotificationSound() {
        const audio = new Audio('/notification.mp3');
        audio.play().catch(e => console.log('Audio play failed:', e));
    }
    
    // Handle Enter key
    $('#messageInput').keydown(function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            $('#chatForm').submit();
        }
    });
    
    // Auto-refresh messages every 30 seconds
    setInterval(function() {
        $.get('/chat/api/messages', function(data) {
            if (data.success && data.messages.length > 0) {
                // You could update messages here if needed
            }
        });
    }, 30000);
    
    // Debug socket events
    socket.on('connect', () => {
        console.log('Socket connected:', socket.id);
        $('#statusBadge').html('<i class="fas fa-circle me-1"></i> Connected');
    });
    
    socket.on('disconnect', () => {
        console.log('Socket disconnected');
        $('#statusBadge').html('<i class="fas fa-circle me-1 text-danger"></i> Disconnected');
    });
    
    socket.on('connect_error', (error) => {
        console.error('Socket connection error:', error);
        $('#statusBadge').html('<i class="fas fa-circle me-1 text-warning"></i> Connection Error');
    });
});
</script>

<!-- Styles -->
<style>
.chat-messages {
    scroll-behavior: smooth;
}

.chat-messages::-webkit-scrollbar {
    width: 6px;
}

.chat-messages::-webkit-scrollbar-track {
    background: #f1f1f1;
}

.chat-messages::-webkit-scrollbar-thumb {
    background: #888;
    border-radius: 3px;
}

.chat-messages::-webkit-scrollbar-thumb:hover {
    background: #555;
}

.message-content {
    word-wrap: break-word;
    white-space: pre-wrap;
}

#statusBadge {
    font-size: 0.8rem;
    padding: 0.25rem 0.5rem;
}
</style>